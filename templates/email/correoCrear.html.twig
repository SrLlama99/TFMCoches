<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Correo creación cuenta</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, Helvetica, sans-serif;
        }

        body{
            background-color:#e5e5e5;
            padding:40px 0;
        }

        .main-table{
            width:100%;
        }

        .container{
            width:700px;
            margin:auto;
            background:white;
            border-radius:25px;
            overflow:hidden;
            box-shadow:0 10px 30px rgba(0,0,0,0.2);
        }

        .left{
            width:55%;
            background:linear-gradient(to bottom, #c40000 0%, #780000 100%);
            padding:40px;
            text-align:center;
            color:white;
        }

        .right{
            width:45%;
            background-color:#e5e5e5;
            padding:50px 40px;
        }

        .logo{
            width:100%;
            max-width:320px;
            margin-bottom:30px;
        }

        .title-left{
            font-size:48px;
            margin-bottom:20px;
        }

        .text-left{
            font-size:18px;
            line-height:1.6;
            opacity:0.9;
        }

        .title-right{
            color:#9e2b25;
            font-size:32px;
            margin-bottom:25px;
            text-align:center;
        }

        .text-right{
            color:#333;
            font-size:16px;
            line-height:1.7;
            margin-bottom:30px;
            text-align:center;
        }

        .code-box{
            background-color:#9e2b25;
            border-radius:20px;
            padding:25px;
            text-align:center;
            margin-bottom:30px;
        }

        .code-label{
            color:white;
            font-size:18px;
            margin-bottom:10px;
        }

        .code{
            color:white;
            font-size:42px;
            font-weight:bold;
            letter-spacing:8px;
        }

        .footer-text{
            color:#666;
            font-size:14px;
            text-align:center;
            line-height:1.5;
        }
    </style>

</head>
<body>
<table class="main-table" cellpadding="0" cellspacing="0">
    <tr>
        <td align="center">
            <table class="container" cellpadding="0" cellspacing="0">
                <tr>
                    <td class="left">

                        <img src="cid:carsimg" width="320">

                        <p class="text-left">
                            Bienvenido a la plataforma.
                            Estamos encantados de tenerte con nosotros.
                        </p>

                    </td>

                    <td class="right">

                        <h2 class="title-right">
                            Hola {{ nombre }}!
                        </h2>

                        <p class="text-right">
                            Gracias por crear una cuenta
                        </p>

                        <div class="code-box">

                            <p class="code-label">
                                Tu código de verificación es:
                            </p>

                            <div class="code">
                                {{ valiCode }}
                            </div>

                        </div>

                        <p class="footer-text">
                            Si no has solicitado esta cuenta,
                            puedes ignorar este correo.
                        </p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>

</body>
</html>