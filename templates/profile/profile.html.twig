{% extends "skeleton.html.twig" %}

{% block stylesheets %}
	<style>
		.gallery-section {
			max-width: 1000px;
			margin: 0 auto;
		}

		.carousel-flex-layout {
			display: flex;
			align-items: center;
			gap: 15px;
		}

		/* MOTOR DEL CARRUSEL */
		.custom-scroll-container {
			display: flex !important;
			overflow: hidden;
			scroll-behavior: smooth;
			width: 100%;
			padding: 20px 0;
		}

		.no-smooth {
			scroll-behavior: auto !important;
		}

		.custom-item {
			flex: 0 0 100%;
			min-width: 100%;
			padding: 0 10px;
			box-sizing: border-box;
		}

		@media(min-width: 768px) {
			.custom-item {
				flex: 0 0 33.333%;
				min-width: 33.333%;
			}
		}

		/* PERFIL Y COMENTARIOS */
		.profile-card-custom {
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-items: center;
			text-align: center;
		}

		.comments-section {
			background: #f8f9fa;
			border-radius: 18px;
			padding: 20px;
			max-height: 400px;
			overflow-y: auto;
		}

		.comment-bubble {
			background: white;
			padding: 12px 15px;
			border-radius: 12px;
			margin-bottom: 12px;
			box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
			border-left: 4px solid #007bff;
		}

		.comment-author {
			font-weight: bold;
			font-size: 0.85rem;
			display: block;
			margin-bottom: 3px;
		}

		.comment-text {
			font-size: 0.9rem;
			color: #555;
			margin: 0;
		}

		/* TARJETAS DE LA GALERÍA */
		.card-gallery {
			background: #fff;
			border-radius: 18px;
			overflow: hidden;
			box-shadow: 0 6px 15px rgba(0, 0, 0, 0.1);
			display: flex;
			flex-direction: column;
			height: 100%;
			transition: transform 0.3s ease;
		}

		.img-container-rel {
			position: relative;
			width: 100%;
			aspect-ratio: 1 / 1;
		}

		.img-square {
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
		}

		.texto-traslucido {
			position: absolute;
			bottom: 0;
			width: 100%;
			background: rgba(0, 0, 0, 0.7);
			color: white;
			padding: 10px 15px;
			backdrop-filter: blur(8px);
			font-size: 0.85rem;
			font-weight: 600;
			display: flex;
			justify-content: space-between;
			align-items: center;
		}

		.img-mini-overlay {
			width: 22px;
			height: 22px;
			object-fit: contain;
		}

		.banda-inferior {
			background: #ffffff;
			color: #333;
			padding: 15px;
			border-top: 1px solid #eee;
			text-align: center;
		}

		.texto-detalle {
			font-size: 0.85rem;
			line-height: 1.4;
			margin: 0;
		}

		/* BOTONES NAVEGACIÓN */
		.nav-btn {
			background: #222;
			color: white;
			border: none;
			width: 48px;
			height: 48px;
			border-radius: 50%;
			display: flex;
			align-items: center;
			justify-content: center;
			cursor: pointer;
			transition: all 0.2s;
			flex-shrink: 0;
		}

		.nav-btn:hover {
			background: #000;
			transform: scale(1.1);
		}

		.arrow {
			border: solid white;
			border-width: 0 3px 3px 0;
			display: inline-block;
			padding: 4px;
		}
		.right {
			transform: rotate(-45deg);
		}
		.left {
			transform: rotate(135deg);
		}

		.comments-section {
			background: #ffffff;
			border-radius: 18px;
			max-height: 450px;
			overflow-y: auto;
			padding-right: 5px;
		}

		/* Contenedor del comentario */
		.comment-item {
			display: flex;
			align-items: flex-start;
			gap: 12px;
			padding: 15px;
			margin-bottom: 15px;
			background: #fdfdfd;
			border-radius: 15px;
			border: 1px solid #eee;
			transition: all 0.3s ease;
		}

		.comment-item:hover {
			transform: translateX(5px);
			background: #f8f9ff;
			border-color: #007bff;
		}

		/* Cuerpo del texto */
		.comment-body {
			flex-grow: 1;
		}

		.comment-author {
			font-weight: 700;
			font-size: 0.9rem;
			color: #222;
			margin-bottom: 2px;
			display: block;
		}

		.comment-text {
			font-size: 0.88rem;
			color: #555;
			margin: 0;
			line-height: 1.4;
		}

		/* Personalización de la barra de scroll */
		.comments-section::-webkit-scrollbar {
			width: 6px;
		}
		.comments-section::-webkit-scrollbar-thumb {
			background: #ccc;
			border-radius: 10px;
		}

		/* Componente de Estrellas Solo Lectura */
		.rating-static {
			display: flex;
			justify-content: center; /* Centrado en el carrusel */
			gap: 0.2rem;
			margin: 5px 0;
		}

		.rating-static svg {
			width: 1.1rem;
			height: 1.1rem;
			fill: #e8e8e8; /* Gris para estrellas vacías */
		}

		.rating-static .gold {
			fill: #ffca08; /* Dorado para estrellas llenas */
			filter: drop-shadow(0 0 2px rgba(255, 202, 8, 0.3));
		}

		/* Ajuste de la banda inferior para que las estrellas luzcan mejor */
		.banda-inferior {
			background: #ffffff;
			padding: 12px;
			border-top: 1px solid #eee;
			display: flex;
			justify-content: center;
			align-items: center;
		}

		.comment-avatar {
			width: 50px;
			height: 50px;
			object-fit: contain; /* Esto hace que la imagen se adapte sin cortarse */
			background-color: #f8f9fa;
			flex-shrink: 0;
			border-radius: 8px;
			border: 1px solid #eee;
			padding: 4px; /* Un poco de margen interno para logos */
		}
	</style>
{% endblock %}

